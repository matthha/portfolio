nents/Page';\nimport Footer from './components/Footer';\n// Use app to load the components that we want. \n// Utilize screen state to select the right components with the right information.\nimport {useState} from \"react\";\nimport LeanManufacturing from './components/Screens/LeanManufacturing';\nimport Learn from './components/Screens/Learn';\n\n\nfunction App() {\n  const [screen, setScreen] = useState(\"Basic\");\n  return (\n    <div className=\"App\">\n      <header className=\"App-header\">      \n      </header>\n      <Header />\n      <Nav setScreen={setScreen} /> \n      <Page screen={screen} />\n      {screen === 'Learn' && <Learn screen={screen} setScreen={setScreen}/>}\n      <Footer /> \n    </div>\n  );\n}\n\nexport default App;\n","/workspaces/portfolio/src/reportWebVitals.js",[],[],"/workspaces/portfolio/src/components/Nav.js",["73"],[],"import {useState} from \"react\";\n\n\n// onInput={(e) => inputHandler(e, stateName)}\nconst Nav = ( {setScreen} ) => {\n\n    return (\n        <div className=\"nav grid g5\">\n        \n        <h1 className='b' >About Us</h1>\n        <h1 className='b' onClick={(e) => setScreen('Learn')}>Learn</h1>\n        <h1 className='b'>Teach</h1>\n        <h1 className='b'>Partner</h1>\n        <h1 className='b'>FAQ</h1>\n        </div>\n    )\n\n}\nexport default Nav;","/workspaces/portfolio/src/components/Header.js",["74"],[],"import {useState} from \"react\";\n\nconst Header = () => {\n\n    return (\n        <div className=\"grid\">\n        <img width=\"198\" height=\"36\" src=\"https://nexus.engin.umich.edu/wp-content/uploads/2022/10/nexus-ME-logo-formal.svg\" className=\"custom-logo astra-logo-svg entered lazyloaded\" alt=\"Nexus at Michigan Engineering\" decoding=\"async\" data-lazy-src=\"https://nexus.engin.umich.edu/wp-content/uploads/2022/10/nexus-ME-logo-formal.svg\" data-ll-status=\"loaded\"></img>\n        <div className=\"grid g4\">\n            <div className='b'>Contact</div>\n            <div className='b'>Give</div>\n            <div className='b'>News</div>\n            <div className='b'>Search</div>\n        </div>\n        </div>\n    )\n\n}\nexport default Header;","/workspaces/portfolio/src/components/Footer.js",[],[],"/workspaces/portfolio/src/components/Splash.js",[],[],"/workspaces/portfolio/src/components/Page.js",[],[],"/workspaces/portfolio/src/components/Screens/Learn.js",[],[],"/workspaces/portfolio/src/components/Screens/LeanManufacturing.js",[],[],"/workspaces/portfolio/src/Pages.js",[],[],"/workspaces/portfolio/src/components/Courses.js",[],[],"/workspaces/portfolio/src/components/Screens/Basic.js",["75"],[],"import { theCourses } from \"../Courses\"\nconst Basic = ({screen, setScreen}) => {\n    return (\n        <div>\n            This is the new site.\n            {/* map through the courses to show what's available, create the cards in map */}\n            <div className=\"g4\">\n               <p>Thing Here</p>\n               <p>Other Object</p>\n               <p>Still Thing</p>\n            </div>\n        </div>\n    )\n    // {results.length > 0 && results.map((result, index) => <li key={index} onClick={(e) => chooseResult(result)}>{result}</li>)}\n}\nexport default Basic",{"ruleId":"76","severity":1,"message":"77","line":6,"column":8,"nodeType":"78","messageId":"79","endLine":6,"endColumn":14},{"ruleId":"76","severity":1,"message":"80","line":12,"column":8,"nodeType":"78","messageId":"79","endLine":12,"endColumn":25},{"ruleId":"76","severity":1,"message":"81","line":1,"column":9,"nodeType":"78","messageId":"79","endLine":1,"endColumn":17},{"ruleId":"76","severity":1,"message":"81","line":1,"column":9,"nodeType":"78","messageId":"79","endLine":1,"endColumn":17},{"ruleId":"76","severity":1,"message":"82","line":1,"column":10,"nodeType":"78","messageId":"79","endLine":1,"endColumn":20},"no-unused-vars","'Splash' is defined but never used.","Identifier","unusedVar","'LeanManufacturing' is defined but never used.","'useState' is defined but n