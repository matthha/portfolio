r Object</p>\n               <p>Still Thing</p>\n            </div>\n        </div>\n    )\n    // {results.length > 0 && results.map((result, index) => <li key={index} onClick={(e) => chooseResult(result)}>{result}</li>)}\n}\nexport default Basic",{"ruleId":"75","severity":1,"message":"76","line":6,"column":8,"nodeType":"77","messageId":"78","endLine":6,"endColumn":14},{"ruleId":"75","severity":1,"message":"79","line":12,"column":8,"nodeType":"77","messageId":"78","endLine":12,"endColumn":25},{"ruleId":"75","severity":1,"message":"80","line":1,"column":9,"nodeType":"77","messageId":"78","endLine":1,"endColumn":17},{"ruleId":"75","severity":1,"message":"80","line":1,"column":9,"nodeType":"77","messageId":"78","endLine":1,"endColumn":17},{"ruleId":"75","severity":1,"message":"81","line":1,"column":10,"nodeType":"77","messageId":"78","endLine":1,"endColumn":20},"no-unused-vars","'Splash' is defined but never used.","Identifier","unusedVar","'LeanManufacturing' is defined but never used.","'useState' is defined but never used.","'theCourses' is defined but never used."]